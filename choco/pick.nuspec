<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
  <metadata>
    <id>pick</id>
    <version>$VERSION$</version>
    <title>pick</title>
    <authors>Aryan Bhosale</authors>
    <owners>aryanbhosale</owners>
    <projectUrl>https://pick-cli.pages.dev</projectUrl>
    <projectSourceUrl>https://github.com/aryanbhosale/pick</projectSourceUrl>
    <bugTrackerUrl>https://github.com/aryanbhosale/pick/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/aryanbhosale/pick/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>Extract, filter, and transform values from any format</summary>
    <description>Extract values from anything — JSON, YAML, TOML, .env, HTTP headers, logfmt, CSV, and more. Auto-detects the input format and lets you extract, filter, and transform values using a unified selector syntax. Features pipes, select() filters with regex, array slicing, recursive descent, set/del mutations, output format conversion, and JSONL streaming.</description>
    <tags>cli json yaml toml env logfmt csv parser extract jq filter pipe stream</tags>
  </metadata>
</package>
