<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.chocolatey.org/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>pick</id>
    <version>$VERSION$</version>
    <title>pick</title>
    <authors>Aryan Bhosale</authors>
    <owners>aryanbhosale</owners>
    <projectUrl>https://pick-cli.pages.dev</projectUrl>
    <projectSourceUrl>https://github.com/aryanbhosale/pick</projectSourceUrl>
    <bugTrackerUrl>https://github.com/aryanbhosale/pick/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/aryanbhosale/pick/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>Extract values from anything</summary>
    <description>Extract values from anything — JSON, YAML, TOML, .env, HTTP headers, logfmt, CSV, and more. Auto-detects the input format and lets you extract values using a simple selector syntax.</description>
    <tags>cli json yaml toml env logfmt csv parser extract jq</tags>
  </metadata>
</package>
